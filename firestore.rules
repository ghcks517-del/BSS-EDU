rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /users/{userId} {
      allow get: if true;
      allow create: if true;
      allow update, delete: if true;
      allow list: if true;
    }
  }
}
