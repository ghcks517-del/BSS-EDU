{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Safe-Ed Guide application",
      "type": "object",
      "properties": {
        "company": {
          "type": "string",
          "description": "Company name"
        },
        "name": {
          "type": "string",
          "description": "User's name"
        },
        "birth": {
          "type": "string",
          "description": "Date of birth (YYMMDD)"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        },
        "signupDate": {
          "type": "string",
          "description": "ISO date string of signup"
        },
        "validUntil": {
          "type": "string",
          "description": "ISO date string of validity"
        }
      },
      "required": ["company", "name", "birth", "phone", "signupDate", "validUntil"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Registered users"
    }
  }
}
